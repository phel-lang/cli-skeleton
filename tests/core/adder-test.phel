(ns cli-skeleton-tests.core.adder-test
  (:require cli-skeleton.core.adder :refer [adder])
  (:require phel.test :refer [deftest is]))

;; CORE tests: pure logic, literal data in/out. No CLI harness, no mocks.

(deftest test-adder
  (is (= 0 (adder)))
  (is (= 6 (adder 1 2 3)))
  (is (= -1 (adder 2 -3))))
