(ns cli-skeleton-tests.commands.greet-test
  (:require phel.cli :as cli)
  (:require phel.test :refer [deftest is])
  (:require cli-skeleton.commands.greet :refer [greet-command]))

(defn- exec [args]
  (let [app    (cli/application "test" [greet-command])
        input  (cli/argv (cons "greet" args))
        output (cli/buffered-output)
        code   (cli/run app input output)]
    {:code code :out (cli/output->string output)}))

(deftest test-greet-with-name
  (let [{:keys [code out]} (exec ["alice"])]
    (is (= 0 code))
    (is (cli/output-contains? out "Hello, alice!"))))

(deftest test-greet-loud
  (let [{:keys [code out]} (exec ["alice" "--loud"])]
    (is (= 0 code))
    (is (cli/output-contains? out "HELLO, ALICE!"))))
