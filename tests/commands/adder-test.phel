(ns cli-skeleton-tests.commands.adder-test
  (:require phel.cli :as cli)
  (:require phel.test :refer [deftest is])
  (:require cli-skeleton.commands.adder :refer [adder-command]))

(defn- exec [args]
  (let [app    (cli/application "test" [adder-command])
        input  (cli/argv (cons "add" args))
        output (cli/buffered-output)
        code   (cli/run app input output)]
    {:code code :out (cli/output->string output)}))

(deftest test-add-prints-sum
  (let [{:keys [code out]} (exec ["1" "2" "3"])]
    (is (= 0 code))
    (is (cli/output-contains? out "Sum = 6"))))

(deftest test-add-without-args-warns
  (let [{:keys [code out]} (exec [])]
    (is (= 1 code))
    (is (cli/output-contains? out "at least one"))))
